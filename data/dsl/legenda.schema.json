{
  "$schema": "http://json-schema.org/draft/2020-12/schema",
  "title": "Legenda",
  "description": "DSL-agnostic glossary mapping natural-language terms in a scenario to short canonical labels reused across encode/decode prompts.",
  "type": "object",
  "additionalProperties": false,
  "required": ["entries"],
  "properties": {
    "entries": {
      "type": "array",
      "minItems": 1,
      "maxItems": 40,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["term", "label", "kind"],
        "properties": {
          "term": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "label": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9]{0,31}$"
          },
          "kind": {
            "enum": [
              "actor",
              "resource",
              "action",
              "duration",
              "predicate",
              "attribute",
              "other"
            ]
          },
          "notes": {
            "type": "string",
            "maxLength": 200
          }
        }
      }
    }
  }
}
