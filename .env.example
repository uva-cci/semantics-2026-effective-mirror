# Required for any cloud provider referenced in config.yaml.
# Each key is only needed if its provider appears under `models`.
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-api03-...
GEMINI_API_KEY=AI...

# Optional. Override the Ollama daemon URL (default: http://127.0.0.1:11434).
# OLLAMA_HOST=http://127.0.0.1:11434

# Optional. Hugging Face token, required only for gated or private encoders
# referenced under `encodings` in config.yaml.
# HF_TOKEN=hf_...
